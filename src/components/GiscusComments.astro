<section class="comments-section" aria-labelledby="comments-title">
  <div class="comments-heading">
    <p class="eyebrow">DISCUSSION</p>
    <h2 id="comments-title">Comments</h2>
    <p>Sign in with GitHub to join the conversation.</p>
  </div>

  <script is:inline>
    (() => {
      const savedTheme = localStorage.getItem("theme");
      const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      const siteTheme = savedTheme === "light" || savedTheme === "dark" ? savedTheme : systemTheme;
      const giscusTheme = siteTheme === "dark" ? "transparent_dark" : "light";
      document.currentScript?.nextElementSibling?.setAttribute("data-theme", giscusTheme);
    })();
  </script>

  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo="Amy22707/Amy22707.github.io"
    data-repo-id="MDEwOlJlcG9zaXRvcnkzOTc0MzAzOTQ="
    data-category="Announcements"
    data-category-id="DIC_kwDOF7BOes4DAtSE"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="light"
    data-lang="zh-CN"
    crossorigin="anonymous"
    async
  ></script>
</section>
