---
import "../styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Xue Zhiyao's personal website, blog, and projects" } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
  { href: "/", label: "About" },
  { href: "/blog/", label: "Blog" },
  { href: "/projects/", label: "Projects" },
  { href: "/links/", label: "Links" },
];

const active = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="referrer" content="no-referrer" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Amy</title>
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme === "light" || savedTheme === "dark") {
          document.documentElement.dataset.theme = savedTheme;
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-wrap" aria-label="Main navigation">
        <a class="brand" href="/" aria-label="Back to homepage">
          <span class="brand-mark">A</span>
          <span>Amy's Space</span>
        </a>
        <div class="nav-actions">
          <div class="nav-links">
            {navItems.map((item) => (
              <a href={item.href} class:list={{ active: active(item.href) }}>
                {item.label}
              </a>
            ))}
          </div>
          <button class="theme-toggle" type="button" aria-label="Switch color theme" aria-pressed="false">
            <span class="theme-toggle-icon" aria-hidden="true"></span>
            <span class="theme-toggle-text">Theme</span>
          </button>
        </div>
      </nav>
    </header>
    <main class="page-shell">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Amy | Built with Astro</p>
      <a href="https://github.com/Amy22707" target="_blank" rel="noreferrer">GitHub -&gt;</a>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const button = document.querySelector(".theme-toggle");
        const label = document.querySelector(".theme-toggle-text");
        const media = window.matchMedia("(prefers-color-scheme: dark)");

        const getTheme = () => {
          const savedTheme = localStorage.getItem("theme");
          if (savedTheme === "light" || savedTheme === "dark") return savedTheme;
          return media.matches ? "dark" : "light";
        };

        const getGiscusTheme = (theme) => theme === "dark" ? "transparent_dark" : "light";

        const syncGiscusTheme = (theme) => {
          document.querySelectorAll("iframe.giscus-frame").forEach((iframe) => {
            iframe.contentWindow?.postMessage(
            {
              giscus: {
                setConfig: {
                    theme: getGiscusTheme(theme),
                },
              },
            },
            "https://giscus.app"
            );
          });
        };

        const syncGiscusThemeWhenReady = (theme) => {
          syncGiscusTheme(theme);
          window.setTimeout(() => syncGiscusTheme(theme), 600);
          window.setTimeout(() => syncGiscusTheme(theme), 1600);
          window.setTimeout(() => syncGiscusTheme(theme), 3200);
        };

        const paint = () => {
          const theme = getTheme();
          button?.setAttribute("aria-pressed", String(theme === "dark"));
          if (label) label.textContent = theme === "dark" ? "Light" : "Dark";
          syncGiscusThemeWhenReady(theme);
        };

        button?.addEventListener("click", () => {
          const nextTheme = getTheme() === "dark" ? "light" : "dark";
          localStorage.setItem("theme", nextTheme);
          root.dataset.theme = nextTheme;
          paint();
        });

        media.addEventListener("change", () => {
          if (!localStorage.getItem("theme")) paint();
        });

        const observer = new MutationObserver(() => syncGiscusTheme(getTheme()));
        observer.observe(document.body, { childList: true, subtree: true });
        window.addEventListener("load", () => syncGiscusThemeWhenReady(getTheme()));

        paint();
      })();
    </script>
  </body>
</html>
