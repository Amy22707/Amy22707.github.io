---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = await getCollection("projects");
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const selectedProjects = [...projects]
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 3);
const recentPosts = posts.slice(0, 2);

const focuses = [
  { label: "LEARNING", value: "Reinforcement Learning & Agents" },
  { label: "BUILDING", value: "Chinese Standard Mahjong AI" },
  { label: "EXPLORING", value: "New Possibilities across AI & Web" },
];

const skillGroups = [
  { title: "Languages", skills: ["C++", "Python", "TypeScript"] },
  { title: "AI & Data", skills: ["PyTorch", "Machine Learning", "Reinforcement Learning", "NumPy"] },
  { title: "Tools", skills: ["Git", "Linux", "Astro", "LaTeX"] },
];

const beyondCode = [
  {
    number: "01",
    title: "Interests & Hobbies",
    items: [
      "Classical & Contemporary Chinese Poetry",
      "Esotericism",
    ],
  },
  {
    number: "02",
    title: "Campus & Community",
    description: "I value student work, teamwork, and the quiet craft of making a community more welcoming and effective.",
  },
  {
    number: "03",
    title: "Writing & Reflection",
    description: "Beyond technical notes, I write about campus life, personal growth, and ideas that are worth remembering.",
  },
];

// Add your papers, preprints, workshop papers, or technical reports here.
const publications = [
  {
    year: "20XX",
    title: "Your Paper Title",
    authors: "Xue Zhiyao, Coauthor Name",
    venue: "Conference, Journal, Workshop, or arXiv",
    description: "A one-sentence summary of the problem and your contribution.",
    href: "",
    tags: ["tag1", "tag2"],
  },
];


const educationAndExperience = [
    {
    period: "2022.09 — 2025.06",
    type: "Education",
    title: "Senior High School Student",
    organization: "Shanghai High School",
  },

  {
    period: "2025.09 — Present",
    type: "Education",
    title: "Undergraduate",
    organization: "Peking University · EECS",
    description: "Computer Science & Artificial Intelligence",
  },
];


const awards = [
  {
    year: "20XX",
    title: "Award or Honor",
    issuer: "Issuing Organization",
    description: "Add the level, ranking, or a short note about this achievement.",
  },
];
---

<BaseLayout title="About" description="Xue Zhiyao's personal website, writing, and projects">
  <section class="profile-hero">
    <aside class="identity-panel">
      <div class="avatar-wrap">
        <img src="/avatar.jpg" alt="Portrait of Xue Zhiyao" />
        <span class="status-dot" title="Always curious"></span>
      </div>
      <div class="identity-title">
        <h1>Xue Zhiyao</h1>
        <p>薛之瑶</p>
      </div>
      <p class="identity-role">Student · Developer · Explorer</p>
      <ul class="identity-facts">
        <li><span>⌖</span> Beijing, China</li>
        <li><span>◇</span> Peking University</li>
        <li><span>↗</span> EECS & SAI · Zhi Class</li>
      </ul>
      <div class="identity-links">
        <a href="https://github.com/Amy22707" target="_blank" rel="noreferrer">GitHub ↗</a>
        <a href="/links/">Contact →</a>
      </div>
    </aside>

    <div class="intro-panel">
      <p class="eyebrow">SELF · INTRODUCTION</p>
      <h2>Anything one man can imagine,<br /><span>other men can make real.</span></h2>
      <div class="intro-copy">
        <p>
          Hi, I am Xue Zhiyao, an undergraduate at School of Electronics Engineering and Computer Science, Peking University.
          I am currently studying computer science and artificial intelligence. I enjoy understanding why systems work—and turning
          vague ideas into things that actually run.
        </p>
        <p>
          My current interests lie in machine learning, reinforcement learning, intelligent
          agents and embodied AI. This site is a growing record of my work.
        </p>
      </div>
      <div class="intro-actions">
        <a class="button primary" href="/projects/">Explore My Work <span>→</span></a>
        <a class="text-link" href="/blog/">Read My Blog</a>
      </div>
      <div class="mini-stats" aria-label="Website content statistics">
        <div><strong>{String(projects.length).padStart(2, "0")}</strong><span>Projects</span></div>
        <div><strong>{String(posts.length).padStart(2, "0")}</strong><span>Articles</span></div>
        <div><strong>∞</strong><span>Curiosity</span></div>
      </div>
    </div>
  </section>

  <section class="home-section skills-section">
    <header class="home-section-header">
      <div>
        <p class="eyebrow">TECHNICAL TOOLKIT</p>
        <h2>What I work with</h2>
      </div>
      <p class="section-note">Learning by building, one system at a time.</p>
    </header>
    <div class="skill-groups">
      {skillGroups.map((group, index) => (
        <article class="skill-group">
          <div class="skill-group-heading">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{group.title}</h3>
          </div>
          <div class="skill-cloud">
            {group.skills.map((skill) => <span>{skill}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section">
    <header class="home-section-header">
      <div>
        <p class="eyebrow">SELECTED WORK</p>
        <h2>Things I have built</h2>
      </div>
      <a href="/projects/">All projects →</a>
    </header>
    <div class="featured-work-grid">
      {selectedProjects.map((project, index) => (
        <a class="featured-work" href={project.data.repository} target="_blank" rel="noreferrer">
          <div class="work-number">{String(index + 1).padStart(2, "0")}</div>
          <div class="work-copy">
            <div class="work-kicker">{project.data.featured ? "FEATURED PROJECT" : "OPEN SOURCE"}</div>
            <h3>{project.data.title}</h3>
            <p>{project.data.description}</p>
            <div class="tag-row">
              {project.data.technologies.slice(0, 3).map((technology) => <span>{technology}</span>)}
            </div>
          </div>
          <span class="work-arrow">↗</span>
        </a>
      ))}
    </div>
  </section>

  <section class="home-section publications-section">
    <header class="home-section-header">
      <div>
        <p class="eyebrow">PUBLICATIONS</p>
        <h2>Research and writing</h2>
      </div>
      <p class="section-note">Papers, preprints, and technical reports.</p>
    </header>
    <div class="publication-list">
      {publications.map((publication, index) => (
        <article class="publication-card">
          <div class="publication-index">{String(index + 1).padStart(2, "0")}</div>
          <div class="publication-main">
            <div class="publication-meta"><span>{publication.year}</span><span>{publication.venue}</span></div>
            <h3>{publication.title}</h3>
            <p class="publication-authors">{publication.authors}</p>
            <p>{publication.description}</p>
            <div class="tag-row">{publication.tags.map((tag) => <span>{tag}</span>)}</div>
          </div>
          {publication.href && <a class="publication-link" href={publication.href} target="_blank" rel="noreferrer" aria-label={`Open ${publication.title}`}>↗</a>}
        </article>
      ))}
    </div>
  </section>

  <section class="home-section awards-section">
    <header class="home-section-header">
      <div>
        <p class="eyebrow">AWARDS & HONORS</p>
        <h2>Milestones along the way</h2>
      </div>
      <p class="section-note">Recognition for academic, technical, and community work.</p>
    </header>
    <div class="awards-grid">
      {awards.map((award, index) => (
        <article class="award-card">
          <div class="award-topline"><span>{award.year}</span><span>0{index + 1}</span></div>
          <h3>{award.title}</h3>
          <strong>{award.issuer}</strong>
          <p>{award.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section resume-section">
    <header class="home-section-header">
      <div>
        <p class="eyebrow">EDUCATION & EXPERIENCE</p>
        <h2>Where I have learned and worked</h2>
      </div>
      <p class="section-note">A chronological view of my academic and professional journey.</p>
    </header>
    <ol class="resume-timeline">
      {educationAndExperience.map((entry) => (
        <li>
          <time>{entry.period}</time>
          <span class="resume-dot"></span>
          <article>
            <span class="resume-type">{entry.type}</span>
            <h3>{entry.title}</h3>
            <strong>{entry.organization}</strong>
            {entry.description && <p>{entry.description}</p>}
          </article>
        </li>
      ))}
    </ol>
  </section>

<!--
  {/* Current focus section — remove this comment wrapper to show it again.
  <section class="focus-strip late-focus" aria-label="Current focus">
    <div class="focus-heading">
      <span class="live-pulse"></span>
      <strong>NOW</strong>
    </div>
    {focuses.map((focus) => (
      <div class="focus-item">
        <span>{focus.label}</span>
        <strong>{focus.value}</strong>
      </div>
    ))}
  </section>
  */}
-->

  <section class="home-section recent-writing-wide">
    <div class="recent-heading">
      <div><p class="eyebrow">RECENT WRITING</p><h2>From the notebook</h2></div>
      <a href="/blog/">All articles →</a>
    </div>
    <div class="compact-posts">
      {recentPosts.length ? recentPosts.map((post) => (
        <a href={`/blog/${post.id}/`}>
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
          </time>
          <div><h3>{post.data.title}</h3><p>{post.data.description}</p></div>
          <span>→</span>
        </a>
      )) : <p class="empty-note">New notes are on the way.</p>}
    </div>
  </section>

  <section class="home-section beyond-section">
    <header class="home-section-header">
      <div>
        <p class="eyebrow">BEYOND CODE</p>
        <h2>More than a technical profile</h2>
      </div>
      <p class="section-note">The non-technical parts matter, too.</p>
    </header>
    <div class="beyond-grid">
      {beyondCode.map((item) => (
        <article class="beyond-card">
          <span>{item.number}</span>
          <h3>{item.title}</h3>
          {"items" in item ? (
            <ul class="interest-list">
              {item.items.map((interest) => <li>{interest}</li>)}
            </ul>
          ) : (
            <p>{item.description}</p>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
