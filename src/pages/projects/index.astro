---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
---

<BaseLayout title="Projects & Notes" description="Projects and course notes by Xue Zhiyao">
  <section class="page-intro">
    <p class="eyebrow">PROJECTS & NOTES</p>
    <h1>Things I build and learn</h1>
    <p>A collection of my software projects, experiments, and course notes.</p>
  </section>

  <section class="project-grid">
    {projects.map((project) => (
      <a class="project-card" href={project.data.repository} target={project.data.repository ? "_blank" : undefined} rel={project.data.repository ? "noreferrer" : undefined}>
        <div class="project-topline">
          <span>{project.data.featured ? "FEATURED" : project.data.kind === "notes" ? "NOTES" : "PROJECT"}</span>
          <span class="arrow">{project.data.repository ? "↗" : "—"}</span>
        </div>
        <h2>{project.data.title}</h2>
        <p>{project.data.description}</p>
        <div class="tag-row">
          {project.data.technologies.map((technology) => <span>{technology}</span>)}
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
