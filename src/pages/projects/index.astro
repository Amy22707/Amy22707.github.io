---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
---

<BaseLayout title="Projects & Notes" description="Projects and course notes by Xue Zhiyao">
  <section class="page-intro">
    <p class="eyebrow">THINGS I BUILD AND LEARN</p>
    <h1>Projects & Notes</h1>
    <p>A collection of my software projects, experiments, and course notes.</p>
  </section>

  <section class="project-grid">
    {projects.map((project) => {
      const href = project.data.repository ?? project.data.demo;
      const cardContent = (
        <>
          <div class="project-topline">
            <span>{project.data.featured ? "FEATURED" : project.data.kind === "notes" ? "NOTES" : "PROJECT"}</span>
            <span class="arrow">{href ? "↗" : "—"}</span>
          </div>
          <h2>{project.data.title}</h2>
          <p>{project.data.description}</p>
          <div class="tag-row">
            {project.data.technologies.map((technology) => <span>{technology}</span>)}
          </div>
        </>
      );

      return href ? (
        <a class="project-card" href={href} target="_blank" rel="noreferrer">
          {cardContent}
        </a>
      ) : (
        <article class="project-card">
          {cardContent}
        </article>
      );
    })}
  </section>
</BaseLayout>
