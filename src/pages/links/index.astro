---
import BaseLayout from "../../layouts/BaseLayout.astro";

const personalLinks = [
  { title: "GitHub", description: "Code, projects, and open-source work", href: "https://github.com/Amy22707", icon: "GH", type: "link" },
  { title: "Email", description: "zhiyaoxue25@stu.pku.edu.cn", icon: "@", type: "email" },
];

const friendLinks = [
  {
    title: "Mars_Dingdang",
    description: "Research notes, experiments, and fragments worth keeping.",
    href: "https://mars-dingdang.github.io/",
    avatar: "/friends/Mars_Dingdang.jpg",
  },
  {
    title: "Hazy Lane",
    description: "一个更新不勤快的普通人的扭曲幻想合集。",
    href: "https://locallych.top",
    avatar: "https://img.locallych.top/images/{year}/{month}/avatar.webp",
  },
];

const myFriendLink = `{
  title: "Amy_xue",
  description: "The best way to predict the future is to invent it.",
  href: "https://amy22707.github.io/",
  avatar: "https://amy22707.github.io/avatar.jpg",
}`;
---

<BaseLayout title="Links" description="Personal links and friends across the web">
  <section class="page-intro">
    <p class="eyebrow">CONNECT</p>
    <h1>Links</h1>
    <p>A collection of places to find me and people worth discovering.</p>
  </section>

  <section class="link-section">
    <h2>Find Me</h2>
    <div class="link-grid">
      {personalLinks.map((link) => link.type === "email" ? (
        <div class="link-card email-card">
          <span class="link-icon">{link.icon}</span>
          <div><h3>{link.title}</h3><p class="email-address">{link.description}</p></div>
          <button class="copy-email" type="button" data-email={link.description} aria-label="Copy email address">Copy</button>
        </div>
      ) : (
        <a class="link-card" href={link.href} target="_blank" rel="noreferrer">
          <span class="link-icon">{link.icon}</span>
          <div><h3>{link.title}</h3><p>{link.description}</p></div>
          <span class="arrow">↗</span>
        </a>
      ))}
    </div>
  </section>

  <section class="link-section">
    <h2>Friends</h2>
    <div class="link-grid">
      {friendLinks.map((link) => (
        <a class="link-card" href={link.href} target="_blank" rel="noreferrer">
          <img class="friend-avatar" src={link.avatar} alt={`${link.title}'s avatar`} loading="lazy" />
          <div><h3>{link.title}</h3><p>{link.description}</p></div>
          <span class="arrow">↗</span>
        </a>
      ))}
    </div>
    <p class="friend-note">Interested in exchanging links? Feel free to reach out by email.</p>
  </section>

  <section class="link-section friend-exchange-section">
    <div class="friend-exchange-card">
      <div class="friend-exchange-preview">
        <img class="friend-avatar" src="/avatar.jpg" alt="Amy_xue avatar" loading="lazy" />
        <div>
          <p class="eyebrow">FRIEND LINK</p>
          <h2>Add me to your links</h2>
          <p>You can copy this snippet directly if you would like to exchange links.</p>
        </div>
      </div>
      <pre class="friend-snippet"><code>{myFriendLink}</code></pre>
      <button class="copy-friend-link" type="button" data-snippet={myFriendLink}>Copy snippet</button>
    </div>
  </section>
</BaseLayout>

<script>
  const copyText = async (text: string) => {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }

    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.left = "-9999px";
    document.body.appendChild(textarea);
    textarea.select();
    document.execCommand("copy");
    textarea.remove();
  };

  const showCopyStatus = (button: HTMLButtonElement, text: string, resetText: string) => {
    button.textContent = text;
    window.setTimeout(() => { button.textContent = resetText; }, 1600);
  };

  document.querySelectorAll<HTMLButtonElement>(".copy-email").forEach((button) => {
    button.addEventListener("click", async () => {
      const email = button.dataset.email;
      if (!email) return;
      try {
        await copyText(email);
        showCopyStatus(button, "Copied", "Copy");
      } catch {
        showCopyStatus(button, "Copy failed", "Copy");
      }
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".copy-friend-link").forEach((button) => {
    button.addEventListener("click", async () => {
      const snippet = button.dataset.snippet;
      if (!snippet) return;
      try {
        await copyText(snippet);
        showCopyStatus(button, "Copied", "Copy snippet");
      } catch {
        showCopyStatus(button, "Copy failed", "Copy snippet");
      }
    });
  });
</script>
