---
import BaseLayout from "../../layouts/BaseLayout.astro";

const personalLinks = [
  { title: "GitHub", description: "Code, projects, and open-source work", href: "https://github.com/Amy22707", icon: "GH", type: "link" },
  { title: "Email", description: "zhiyaoxue25@stu.pku.edu.cn", icon: "@", type: "email" },
];

const friendLinks = [
  {
    title: "Mars_Dingdang",
    description: "Research notes, experiments, and fragments worth keeping.",
    href: "https://mars-dingdang.github.io/",
    avatar: "https://github.com/Mars-Dingdang.png",
  },
];
---

<BaseLayout title="Links" description="Personal links and friends across the web">
  <section class="page-intro">
    <p class="eyebrow">CONNECT</p>
    <h1>Links</h1>
    <p>The four beauties are present, and the two rare blessings meet.</p>
  </section>

  <section class="link-section">
    <h2>Find Me</h2>
    <div class="link-grid">
      {personalLinks.map((link) => link.type === "email" ? (
        <div class="link-card email-card">
          <span class="link-icon">{link.icon}</span>
          <div><h3>{link.title}</h3><p class="email-address">{link.description}</p></div>
          <button class="copy-email" type="button" data-email={link.description} aria-label="Copy email address">Copy</button>
        </div>
      ) : (
        <a class="link-card" href={link.href} target="_blank" rel="noreferrer">
          <span class="link-icon">{link.icon}</span>
          <div><h3>{link.title}</h3><p>{link.description}</p></div>
          <span class="arrow">↗</span>
        </a>
      ))}
    </div>
  </section>

  <section class="link-section">
    <h2>Friends</h2>
    <div class="link-grid">
      {friendLinks.map((link) => (
        <a class="link-card" href={link.href} target="_blank" rel="noreferrer">
          <img class="friend-avatar" src={link.avatar} alt={`${link.title}'s avatar`} loading="lazy" />
          <div><h3>{link.title}</h3><p>{link.description}</p></div>
          <span class="arrow">↗</span>
        </a>
      ))}
    </div>
    <p class="friend-note">Interested in exchanging links? Feel free to reach out by email.</p>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-email").forEach((button) => {
    button.addEventListener("click", async () => {
      const email = button.dataset.email;
      if (!email) return;
      await navigator.clipboard.writeText(email);
      button.textContent = "Copied";
      window.setTimeout(() => { button.textContent = "Copy"; }, 1600);
    });
  });
</script>
