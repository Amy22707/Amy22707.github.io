---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GiscusComments from "../../components/GiscusComments.astro";
import { getTagHref } from "../../utils/blogTags";

export async function getStaticPaths() {
  const posts = (await getCollection("blog", ({ data }) => !data.draft))
    .sort((a, b) => a.data.publishedAt.valueOf() - b.data.publishedAt.valueOf());

  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      previousPost: posts[index - 1],
      nextPost: posts[index + 1],
    },
  }));
}

const { post, previousPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter((heading) => heading.depth >= 1 && heading.depth <= 4);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <div class:list={["article-layout", tocHeadings.length === 0 && "without-toc"]}>
    {tocHeadings.length > 0 && (
      <aside class="article-toc" aria-label="Table of contents">
        <p>On this page</p>
        <ol>
          {tocHeadings.map((heading) => (
            <li class={`toc-depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </aside>
    )}

    <article class="article-shell">
      <a class="back-link" href="/blog/">← Back to Blog</a>
      <header class="article-header">
        <div class="post-meta">
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString("en-US", {
              year: "numeric", month: "long", day: "numeric"
            })}
          </time>
          <span aria-hidden="true">·</span>
          <div class="post-tags">
            {post.data.tags.map((tag) => <a href={getTagHref(tag)}>#{tag}</a>)}
          </div>
        </div>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
      </header>

      <div class="prose"><Content /></div>

      <nav class="post-navigation" aria-label="Blog post navigation">
        {previousPost ? (
          <a class="post-nav-card previous" href={`/blog/${previousPost.id}/`}>
            <span>Previous</span>
            <strong>{previousPost.data.title}</strong>
          </a>
        ) : (
          <div class="post-nav-card disabled">
            <span>Previous</span>
            <strong>No older post</strong>
          </div>
        )}

        {nextPost ? (
          <a class="post-nav-card next" href={`/blog/${nextPost.id}/`}>
            <span>Next</span>
            <strong>{nextPost.data.title}</strong>
          </a>
        ) : (
          <div class="post-nav-card disabled next">
            <span>Next</span>
            <strong>No newer post</strong>
          </div>
        )}
      </nav>

      <GiscusComments />
    </article>
  </div>
</BaseLayout>
